# ─── Required in production ────────────────────────────────────────────
# 32+ random bytes — used to sign member and admin JWTs.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-to-a-long-random-string

# ─── Future — wire when moving off the demo in-memory store ────────────
# DATABASE_URL=postgresql://user:pass@host:5432/elevations
# DIRECT_URL=postgresql://user:pass@host:5432/elevations

# ─── Future — Yoco hosted-checkout integration ─────────────────────────
# YOCO_SECRET_KEY=
# YOCO_PUBLIC_KEY=
# YOCO_WEBHOOK_SECRET=

# ─── Future — OTP delivery via Twilio or Africa's Talking ──────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
#  — or —
# AT_API_KEY=
# AT_USERNAME=
# AT_FROM=

# ─── Future — Supabase Storage (product images) ────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
